versao="1.0"

; Testa o BRG quando Z = 1.
; CPA gera igualdade, então TBA deve executar porque o desvio não ocorre.

[inicio]
registrador.pc="0"
registrador.a="05"
registrador.b="22"
instrucoes=[
	"CPA #05",
	"BRG 0006",
	"TBA",
	"CAL EXIT"
]

[fim]
registrador.a="22"
registrador.b="22"
flag.n="0"
flag.z="1"
memoria = {
    "000": "27",
    "001": "05",
    "002": "A4",
    "003": "00",
    "004": "06",
    "005": "42",
    "006": "58",
    "007": "12",
    "008": "00",
}
