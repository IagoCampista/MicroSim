versao="1.0"

; Testa o PPB restaurando B a partir da pilha.

[inicio]
registrador.pc="0"
registrador.pp="0FFF"
registrador.a="12"
registrador.b="34"
instrucoes=[
	"PHB",
	"TAB",
	"PPB",
	"CAL EXIT"
]

[fim]
registrador.a="12"
registrador.b="34"
registrador.pp="0FFF"
memoria = {
    "000": "43",
    "001": "41",
    "002": "44",
    "003": "58",
    "004": "12",
    "005": "00",
}
