versao="1.0"

; Testa o BRE quando Z = 1.
; CPA gera igualdade e o desvio deve pular a instrução TBA.

[inicio]
registrador.pc="0"
registrador.a="05"
registrador.b="22"
instrucoes=[
	"CPA #05",
	"BRE 0006",
	"TBA",
	"CAL EXIT"
]

[fim]
registrador.a="05"
registrador.b="22"
flag.z="1"
memoria = {
    "000": "27",
    "001": "05",
    "002": "A0",
    "003": "00",
    "004": "06",
    "005": "42",
    "006": "58",
    "007": "12",
    "008": "00",
}
